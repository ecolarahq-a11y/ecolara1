{
  "expo": {
    "name": "EcoLara",
    "slug": "ecolara",
    "scheme": "ecolara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/ecolara-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D2818"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ecolara.app"
    },
    "android": {
      "package": "com.ecolara.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D2818"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
